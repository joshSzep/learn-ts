{
  "name": "hello_world_modern",
  "version": "1.0.0",
  "description": "A tiny modern TypeScript CLI for learning typed modules, Commander-based parsing, clean builds, and tests.",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "hello-world-modern": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "start": "node dist/index.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
